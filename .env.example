APP_NAME="Floristería Bribri"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=floristeria_bribri
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Correo (configurar con tu proveedor SMTP) ─────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_de_gmail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tu_correo@gmail.com
MAIL_FROM_NAME="Floristería Bribri"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Variables del negocio ─────────────────────────────────
FLORISTERIA_NOMBRE="Floristería Bribri"
FLORISTERIA_SLOGAN="Flores frescas con amor desde Costa Rica"
FLORISTERIA_WHATSAPP=50600000000
FLORISTERIA_ADMIN_EMAIL=admin@ejemplo.com
FLORISTERIA_HORARIO="Lunes a Sábado: 8:00am - 6:00pm"
FLORISTERIA_DIRECCION="Bribri, Talamanca, Limón"
FLORISTERIA_COSTO_ENVIO=3000

# ── Redes sociales (opcional, dejar vacío si no aplica) ───
FLORISTERIA_FACEBOOK=
FLORISTERIA_INSTAGRAM=
FLORISTERIA_TIKTOK=